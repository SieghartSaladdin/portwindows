# Choose your LLM provider: 'openrouter' or 'ollama'
LLM_PROVIDER=openrouter

# --- OpenRouter Configuration ---
# Required if LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Ollama Configuration ---
# Required if LLM_PROVIDER=ollama
# Note: Use 'http://host.docker.internal:11434' if running in Docker and Ollama is on the host machine.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2
