datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

model Profile {
  id          String  @id @default("1")
  name        String
  title       String
  location    String
  email       String
  bio         String
  githubUrl   String?
  linkedinUrl String?
}

model Project {
  id          String  @id @default(uuid())
  title       String
  description String
  tags        Json    // Store as JSON array of strings
  githubUrl   String?
  liveUrl     String?
}

model Skill {
  id       String @id @default(uuid())
  category String
  skills   Json    // Store as JSON array of strings
}

model Experience {
  id          String @id @default(uuid())
  role        String
  company     String
  duration    String
  description Json   // Store as JSON array of strings
}
